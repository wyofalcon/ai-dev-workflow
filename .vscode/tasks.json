        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 Audit Watch",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/audit-watch.sh",

{
  "version": "2.0.0",
  "tasks": [
    // ═══════════════════════════════════════════════════════════
    // AI WORKFLOW TASKS (from .ai-workflow/ - reusable template)
    // ═══════════════════════════════════════════════════════════
    {
      "label": "👁️ Watch Builder",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/watch-builder.sh",
      "isBackground": true,
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🎯 Builder Setup",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/config/builder-setup.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 Audit Watch",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/audit-watch.sh",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "group": "dev-workflow"
      },
      "problemMatcher": []
    },
    {
      "label": "🔍 Audit Watch + Copilot",
      "type": "shell",
      "command": "COPILOT_REVIEW=1 ${workspaceFolder}/.ai-workflow/scripts/audit-watch.sh",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "group": "dev-workflow"
      },
      "problemMatcher": []
    },
    {
      "label": "🤖 Copilot Review (Staged)",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/copilot-review.sh",
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🧠 Copilot Review (Opus)",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/copilot-review.sh --opus",
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🤖 AI Builder",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/start-builder-tmux.sh",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "group": "dev-workflow"
      },
      "problemMatcher": []
    },
    {
      "label": "🔄 GH Ops Delegate",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/start-gh-ops-tmux.sh",
      "isBackground": true
    },
    {
      "label": "🧠 AI Auditor Delegate",
      "type": "shell",
      "command": "${workspaceFolder}/.ai-workflow/scripts/start-auditor-ai-tmux.sh",
      "isBackground": true
    },
    {
      "label": "🖥️ Split Terminals",
      "dependsOn": ["🔍 Audit Watch", "🤖 AI Builder", "🔄 GH Ops Delegate", "🧠 AI Auditor Delegate"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "🚀 Start Dev Workflow",
      "dependsOn": ["🎯 Builder Setup", "🖥️ Split Terminals"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "📊 Workflow Signals",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/scripts/workflow-signals.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔎 Builder Status",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/scripts/builder-status.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": " Show Workflow Status",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/scripts/show-status.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "⚙️ Toggle Relay Mode",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/scripts/toggle-relay-mode.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "📤 Send Prompt to Builder",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/scripts/send-prompt.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "🔄 Toggle Audit Watch",
      "type": "shell",
      "command": "bash ${workspaceFolder}/.ai-workflow/scripts/toggle-audit-watch.sh",
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "�🚀 Promote Branch",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/promote.py",
      "group": "deploy",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Interactively promote code (Dev -> Staging -> Prod) with diff review."
    },
    {
      "label": "Git Sync",
      "type": "shell",
      "command": "./git-sync.sh",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Stages, commits, pulls, and pushes changes to Git."
    },
    {
      "label": "Run E2E Tests (UI Mode)",
      "type": "shell",
      "command": "npm run test:e2e:ui",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": [],
      "detail": "Run Playwright tests with interactive UI - best for monitoring"
    },
    {
      "label": "Run E2E Tests (Headed)",
      "type": "shell",
      "command": "npm run test:e2e:headed",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "detail": "Run tests with browser visible"
    },
    {
      "label": "Run E2E Tests (Headless)",
      "type": "shell",
      "command": "npm run test:e2e",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Run all tests in headless mode (fast)"
    },
    {
      "label": "Show Test Report",
      "type": "shell",
      "command": "npm run test:report",
      "presentation": {
        "reveal": "never",
        "panel": "new"
      },
      "problemMatcher": [],
      "detail": "Open HTML test report in browser"
    },
    {
      "label": "Start All Services",
      "type": "shell",
      "command": "docker compose up -d",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Start database, redis, backend, and frontend containers"
    },
    {
      "label": "Stop All Services",
      "type": "shell",
      "command": "docker compose down",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Stop all running containers"
    },
    {
      "label": "View Container Logs",
      "type": "shell",
      "command": "docker compose logs -f --tail=100",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": [],
      "detail": "Follow logs from all containers"
    },
    {
      "label": "Run Backend Tests",
      "type": "shell",
      "command": "cd api && npm test",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Run Jest unit/integration tests for the API"
    },
    {
      "label": "Prisma Studio",
      "type": "shell",
      "command": "cd api && npx prisma studio",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "detail": "Open Prisma Studio to view/edit database"
    },
    {
      "label": "Reset Database",
      "type": "shell",
      "command": "docker compose down -v && docker compose up -d && sleep 5 && cd api && npx prisma migrate dev",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "⚠️ Destroys all data and recreates database"
    }
  ]
}
